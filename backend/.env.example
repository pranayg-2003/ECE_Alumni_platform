# Server Configuration
PORT=5000

# Optional extra browser origins (no trailing slash), merged with built-in defaults including
# https://ece-alumni-platform.vercel.app and localhost. Add new Vercel preview URLs here if needed.
# CLIENT_ORIGIN=https://your-preview.vercel.app

# MongoDB Connection String
# Replace with your MongoDB Atlas URI or local URI.
# On Windows, mongodb+srv:// sometimes fails with "querySrv ECONNREFUSED"; use the standard
# mongodb:// URI (all shard hostnames + replicaSet + tls) from Atlas Connect or Compass instead.
MONGO_URI=mongodb://localhost:27017/mentorship_platform

# JWT Secret Key - Use a long random string in production!
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# JWT Expiry
JWT_EXPIRE=7d

# Cloudinary (post photos & documents)
# https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
# Optional folder prefix for uploads
CLOUDINARY_FOLDER=mentorship-posts

# --- Email (pick one) ---
# Recommended on Render: Resend over HTTPS (Gmail SMTP often times out with ETIMEDOUT on cloud hosts).
# https://resend.com/api-keys — add key in Render → Environment
# RESEND_API_KEY=re_xxxxxxxx
# After verifying your domain in Resend: RESEND_FROM=Your App <noreply@yourdomain.com>
# If unset, sends from Resend’s test address (limited; verify a domain for production).

# Optional: Gmail SMTP (works locally; often blocked or slow from Render)
# https://myaccount.google.com/apppasswords
# SMTP_USER=your.email@gmail.com
# SMTP_PASS=abcdefghijklmnop
# SMTP_FROM=your.email@gmail.com

# APP_NAME=MentorBridge
# Optional cap on mail send (ms)
# SMTP_SEND_TIMEOUT_MS=25000

# Required for admin signup: must match the value typed in the register form. Use 8+ characters in production.
# Server loads backend/.env from the backend folder — restart after changing this.
ADMIN_REGISTER_SECRET=change_this_long_random_secret

# Razorpay (INR payments for funding campaigns) — https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=dsds
RAZORPAY_KEY_SECRET=cvvd
