# Server Configuration
PORT=5000

# MongoDB Connection String
# Replace with your MongoDB Atlas URI or local URI.
# On Windows, mongodb+srv:// sometimes fails with "querySrv ECONNREFUSED"; use the standard
# mongodb:// URI (all shard hostnames + replicaSet + tls) from Atlas Connect or Compass instead.
MONGO_URI=mongodb://localhost:27017/mentorship_platform

# JWT Secret Key - Use a long random string in production!
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# JWT Expiry
JWT_EXPIRE=7d

# Cloudinary (post photos & documents)
# https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
# Optional folder prefix for uploads
CLOUDINARY_FOLDER=mentorship-posts

# Password reset (Gmail): 2-Step Verification must be on, then create an App Password
# https://myaccount.google.com/apppasswords
# SMTP_USER must be the same Gmail address. App Password may be shown with spaces; both work.
SMTP_USER=your.email@gmail.com
SMTP_PASS=abcdefghijklmnop
# Optional "From" display; defaults to SMTP_USER
# SMTP_FROM=your.email@gmail.com
# APP_NAME=MentorBridge

# Razorpay (INR payments for funding campaigns) — https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=dfsdf
RAZORPAY_KEY_SECRET=cvvd
